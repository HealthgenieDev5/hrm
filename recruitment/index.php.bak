																<th title="Selected"><i class="text-dark fas fa-check-double"></i></th>
																<th title="Rejected"><i class="text-dark fas fa-user-times"></i></th>
																<th>Created On</th>
																<th>TC Date</th>
																<th>EC Date</th>
															</tr>
														</tfoot>
														<tbody>
															<?php
