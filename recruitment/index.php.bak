												<?php
												$job_listing_sql = "select jl.id as ID, jl.listing_title as listing_title, 
												p.position_name as position_name, 
												jl.min_experience as min_experience, 
												jl.max_experience as max_experience, 
												jl.min_budget as min_budget, 
												jl.max_budget as max_budget, 
												jl.job_location as job_location, 
												d.department_name as department_name, 
												c.company_name as company_name, 
												jl.date_time as date_time, 
												jl.target_closure_date  as target_closure_date, 
												jl.expected_closure_date as expected_closure_date, 
												jl.listing_status as listing_status,
												( select count(id) from candidates where disposition_id in (select id from dispositions where disposition_name in ('contacted')) ) as contacted, 
												( select count(id) from candidates where disposition_id in (select id from dispositions where disposition_name in ('interviewed')) ) as interviewed, 
												( select count(id) from candidates where disposition_id in (select id from dispositions where disposition_name in ('shortlisted')) ) as shortlisted, 
												( select count(id) from candidates where disposition_id in (select id from dispositions where disposition_name in ('selected')) ) as selected, 
												( select count(id) from candidates where disposition_id in (select id from dispositions where disposition_name in ('rejected')) ) as rejected

												from job_listing jl 
												left join positions p on p.id = jl.position_id 
												left join companies c on c.id = jl.company_id 
												left join departments d on d.id = jl.department_id";


												$job_listing_query = mysqli_query($conn, $job_listing_sql) or die("unable to fetch job listing from database ".mysqli_error($conn));
												if( mysqli_num_rows($job_listing_query) > 0 ){
													?>
