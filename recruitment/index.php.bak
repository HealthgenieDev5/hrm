		})
	</script>

	
	<script src="assets/js/offcanvas.js"></script>
	<script src="assets/js/custom-script.js"></script>

	<script type="text/javascript">
		$(document).ready(function(){
		    $('#target_closure_date').datepicker({
		    	format: 'yyyy-mm-dd'
		    });
		    $('#expected_closure_date').datepicker({
		    	format: 'yyyy-mm-dd'
		    });
		    $('#listing_closure_date').datepicker({
		    	format: 'yyyy-mm-dd'
		    });
		})
	</script>

	<?php
	if( isset($create_listing_title) && !empty($create_listing_title) && isset($create_listing_message) && !empty($create_listing_message) ){
		if( $create_listing_title == 'Success'){
			?>
			<script type="text/javascript">
				$(document).ready(function(){
					toastr.success("<?php echo $create_listing_message; ?>", "<?php echo $create_listing_title; ?>");
				})
			</script>
			<?php
		}elseif( $create_listing_title == 'Error'){
			?>
			<script type="text/javascript">
				$(document).ready(function(){
					toastr.error("<?php echo $create_listing_message; ?>", "<?php echo $create_listing_title; ?>");
				})
			</script>
			<?php
		}
	}
	?>
</body>
