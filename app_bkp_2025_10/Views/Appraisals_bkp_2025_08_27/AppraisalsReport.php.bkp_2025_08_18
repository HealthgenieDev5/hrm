        function getOrdinal($number)
        {
            $suffixes = ['th', 'st', 'nd', 'rd'];
            $mod100 = $number % 100;
            $suffix = ($mod100 >= 11 && $mod100 <= 13) ? 'th' : ($suffixes[$number % 10] ?? 'th');
            return $number . $suffix;
        }
